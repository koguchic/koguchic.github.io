---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Section order + copy. New kinds slot in here.
const SECTIONS = [
  { kind: 'essay', label: 'Blog', blurb: 'Deep-dives and interactive write-ups.' },
  { kind: 'reading-list', label: 'Reading maps', blurb: 'Curated, trackable paths through a literature.' },
] as const;

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Christian Koguchi — ML field notes">
  <div class="container container--wide">
    <section class="home-hero">
      <p class="eyebrow">Machine learning, in public</p>
      <h1>Learning ML the hard way — one paper at a time<span class="cursor"></span></h1>
      <p>
        Notes, reading maps, and experiments as I work through reinforcement learning, world
        models, and everything I get curious about along the way. Written mostly to think, and to
        keep myself honest about what I actually understand.
      </p>
    </section>

    <div class="filter-bar" role="group" aria-label="Filter by topic">
      <button class="filter-chip" data-tag-chip="all" aria-pressed="true">All</button>
      {
        allTags.map((tag) => (
          <button class="filter-chip" data-tag-chip={tag} aria-pressed="false">
            #{tag}
          </button>
        ))
      }
    </div>

    <div class="hub">
      {
        SECTIONS.map(({ kind, label, blurb }) => {
          const items = posts.filter((p) => p.data.kind === kind);
          return (
            <section class="hub-section" data-section={kind}>
              <div class="section-head">
                <h2 class="section-label">{label}</h2>
                <span class="section-blurb">{blurb}</span>
              </div>
              {items.length === 0 ? (
                <p class="section-empty">As they come.</p>
              ) : (
                items.map((post) => (
                  <a
                    class="post-card"
                    href={`/blog/${post.id}/`}
                    data-tags={post.data.tags.join(' ')}
                  >
                    <div class="post-card__date">{fmt(post.data.pubDate)}</div>
                    <h3 class="post-card__title">{post.data.title}</h3>
                    <p class="post-card__desc">{post.data.description}</p>
                    <div class="tag-row">
                      {post.data.tags.map((tag) => (
                        <span class="tag">{tag}</span>
                      ))}
                    </div>
                  </a>
                ))
              )}
            </section>
          );
        })
      }
    </div>
  </div>

  <script>
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-tag-chip]'));
    const cards = Array.from(document.querySelectorAll<HTMLElement>('.post-card[data-tags]'));
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));
    let active = 'all';

    function apply() {
      cards.forEach((card) => {
        const tags = (card.dataset.tags || '').split(' ');
        card.hidden = !(active === 'all' || tags.includes(active));
      });
      sections.forEach((section) => {
        const owned = section.querySelectorAll<HTMLElement>('.post-card[data-tags]');
        if (owned.length === 0) {
          // Placeholder section (e.g. Projects): only visible in the unfiltered view.
          section.hidden = active !== 'all';
        } else {
          const visible = Array.from(owned).filter((c) => !c.hidden).length;
          section.hidden = visible === 0;
        }
      });
      chips.forEach((chip) => {
        chip.setAttribute('aria-pressed', String(chip.dataset.tagChip === active));
      });
    }

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        active = chip.dataset.tagChip || 'all';
        apply();
      });
    });
  </script>
</BaseLayout>
